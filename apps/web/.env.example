# Apenas variáveis públicas (prefixo NEXT_PUBLIC_) ficam disponíveis no navegador.
# NUNCA coloque segredos aqui.

# URL da API vista pelo browser (same-origin via rewrite do Next.js).
NEXT_PUBLIC_API_BASE_URL=/api

# Destino interno do proxy /api → backend NestJS (somente servidor Next.js).
# Local:
API_INTERNAL_URL=http://localhost:3333
# Vercel (quando a API estiver publicada — ex. Railway/Render):
# API_INTERNAL_URL=https://sua-api.exemplo.com
