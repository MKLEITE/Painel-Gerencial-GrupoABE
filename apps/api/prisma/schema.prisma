generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ATIVO
  SUSPENSO
  INATIVO
}

enum PapelUsuario {
  SUPER_ADMIN
  ADMIN_CREDOR
  OPERADOR
  VIEWER
}

model Tenant {
  id           String       @id @default(uuid()) @db.Uuid
  nome         String
  status       TenantStatus @default(ATIVO)
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")
  usuarios     Usuario[]
  credor       Credor?

  @@map("tenants")
}

/// Credor (cliente do Grupo ABE). 1:1 com Tenant para isolamento multi-tenant.
model Credor {
  id                  String          @id @default(uuid()) @db.Uuid
  tenantId            String          @unique @map("tenant_id") @db.Uuid
  razaoSocial         String          @map("razao_social")
  nomeFantasia        String?         @map("nome_fantasia")
  cnpj                String?
  telefone            String?
  emailComercial      String?         @map("email_comercial")
  setores             String[]        @default([])
  cep                 String?
  cidade              String?
  estado              String?         @db.VarChar(2)
  bairro              String?
  endereco            String?
  numero              String?
  complemento         String?
  paginasAcesso       String[]        @default(["dashboard"]) @map("paginas_acesso")
  codClientePrincipal String?         @map("cod_cliente_principal")
  criadoEm            DateTime        @default(now()) @map("criado_em")
  atualizadoEm        DateTime        @updatedAt @map("atualizado_em")
  tenant              Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  codigosCliente      CodigoCliente[]

  @@index([cnpj])
  @@index([codClientePrincipal])
  @@index([emailComercial])
  @@map("credores")
}

/// Códigos de cliente adicionais (mesmo grupo empresarial, ex.: Coca-Cola filiais).
model CodigoCliente {
  id         String   @id @default(uuid()) @db.Uuid
  credorId   String   @map("credor_id") @db.Uuid
  codCliente String   @map("cod_cliente")
  rotulo     String?
  criadoEm   DateTime @default(now()) @map("criado_em")
  credor     Credor   @relation(fields: [credorId], references: [id], onDelete: Cascade)

  @@unique([credorId, codCliente])
  @@map("codigos_cliente")
}

model Usuario {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  email         String
  nome          String
  telefone      String?
  fotoUrl       String?      @map("foto_url")
  senhaHash     String       @map("senha_hash")
  papel         PapelUsuario
  ativo         Boolean      @default(true)
  mfaHabilitado Boolean      @default(false) @map("mfa_habilitado")
  criadoEm      DateTime     @default(now()) @map("criado_em")
  atualizadoEm  DateTime     @updatedAt @map("atualizado_em")
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([email])
  @@map("usuarios")
}
