NODE_ENV=development
API_PORT=3333
API_GLOBAL_PREFIX=api
WEB_ORIGIN=http://localhost:3000

# Local (Docker): postgresql://postgres:postgres@localhost:5432/painel_abe?schema=public
# AWS RDS (exemplo): postgresql://postgres:SENHA@endpoint.rds.amazonaws.com:5432/postgres?sslmode=require&schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/painel_abe?schema=public

# JWT (trocar os segredos em produção — mínimo 32 caracteres)
JWT_ACCESS_SECRET=dev-access-secret-trocar-em-producao-32c
JWT_REFRESH_SECRET=dev-refresh-secret-trocar-em-producao-32c
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
