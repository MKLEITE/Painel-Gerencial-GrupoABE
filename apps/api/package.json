{
  "name": "@abe/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend (API) do Painel Gerencial Grupo ABE — NestJS",
  "scripts": {
    "build": "prisma generate && nest build",
    "dev": "nest start --watch",
    "postinstall": "prisma generate",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "jest",
    "test:db": "node scripts/test-db-connection.cjs",
    "db:provision": "node scripts/provision-database.cjs",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:setup": "node scripts/provision-database.cjs && prisma generate && prisma migrate deploy && prisma db seed",
    "prisma:generate": "prisma generate",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@abe/canonical-model": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/terminus": "^10.2.3",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@abe/config": "workspace:*",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "eslint": "^9.11.1",
    "jest": "^29.7.0",
    "prisma": "^6.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
