{
  "name": "painel-gerencial-grupoabe",
  "version": "0.1.0",
  "private": true,
  "description": "Painel Gerencial Grupo ABE — portal SaaS de consolidação de cobranças do Grupo ABE",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@abe/web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:seed": "node --env-file=.env supabase/seed.mjs",
    "sync:abeweb": "node --env-file=.env scripts/sync-abeweb-dashboard.mjs --force",
    "sync:abeweb:check": "node --env-file=.env scripts/sync-abeweb-dashboard.mjs --check",
    "sync:abeweb:incremental": "node --env-file=.env scripts/sync-abeweb-dashboard.mjs --incremental",
    "sync:abeweb:watch": "node --env-file=.env scripts/sync-abeweb-watch.mjs",
    "etl:abe": "node --env-file=.env jobs/etl-abe.mjs",
    "test:abedelphi": "node --env-file=.env scripts/test-abedelphi-connection.mjs",
    "explore:abeweb-cliente": "node --env-file=.env scripts/explore-abeweb-cliente.mjs",
    "explore:abedelphi-cliente": "node --env-file=.env scripts/explore-abedelphi-cliente.mjs",
    "provision:credores": "node --env-file=.env scripts/provision-credores.mjs",
    "provision:credores:dry": "node --env-file=.env scripts/provision-credores.mjs --dry-run",
    "backfill:codigos": "node --env-file=.env scripts/backfill-codigos-cadastro.mjs",
    "backfill:codigos:dry": "node --env-file=.env scripts/backfill-codigos-cadastro.mjs --dry-run",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@supabase/supabase-js": "^2.49.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "mssql": "^12.6.0"
  }
}
