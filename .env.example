# ============================================================================
# Variáveis de ambiente — COPIE para .env e preencha localmente.
# NUNCA versione o arquivo .env real (ele está no .gitignore).
# Em produção: Vercel (frontend) + Supabase Dashboard (segredos do banco).
# ============================================================================

NODE_ENV=development

# ---- Supabase (obrigatório) ----
NEXT_PUBLIC_SUPABASE_URL=https://vkzefmedwxvpqcivparz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Apenas servidor (Route Handlers, seed) — NUNCA expor no browser
SUPABASE_SERVICE_ROLE_KEY=

# ---- Frontend (apps/web) ----
# Base das chamadas às Route Handlers do Next.js (same-origin)
NEXT_PUBLIC_API_BASE_URL=/api
