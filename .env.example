# ============================================================================
# Variáveis de ambiente — COPIE para .env e preencha localmente.
# NUNCA versione o arquivo .env real (ele está no .gitignore).
# Em produção: Vercel (frontend) + Supabase Dashboard (segredos do banco).
# ============================================================================

NODE_ENV=development

# ---- Supabase (obrigatório) ----
NEXT_PUBLIC_SUPABASE_URL=https://vkzefmedwxvpqcivparz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Apenas servidor (Route Handlers, seed) — NUNCA expor no browser
SUPABASE_SERVICE_ROLE_KEY=

# ---- Frontend (apps/web) ----
NEXT_PUBLIC_API_BASE_URL=/api

# ---- ABE WEB — SQL Server (sync: pnpm sync:abeweb / pnpm etl:abe) ----
ABEWEB_DB_HOST=
ABEWEB_DB_PORT=1433
ABEWEB_DB_NAME=
ABEWEB_DB_USER=
ABEWEB_DB_PASSWORD=
# ABEWEB_DB_TRUST_CERT=1
# ABEWEB_SYNC_DATA_INICIAL=01/01/2026
# ABEWEB_SYNC_DATA_FINAL=31/12/2026
# ABEWEB_PAGE_SIZE=2000
# ABEWEB_SYNC_INTERVAL_MS=600000
# ABEWEB_STORE_BORDERO_INDICE=1

# ---- ABE Delphi — SQL Server 2005 (mesmas tabelas; conector ETL em breve) ----
# Porta padrão SQL Server = 1433 (só mude se a TI usar outra)
ABEDELPHI_DB_HOST=
ABEDELPHI_DB_PORT=1433
ABEDELPHI_DB_NAME=
ABEDELPHI_DB_USER=
ABEDELPHI_DB_PASSWORD=
# Certificado autoassinado / rede interna (comum no legado)
# ABEDELPHI_DB_TRUST_CERT=1
# ABEDELPHI_DB_ENCRYPT=0

# ---- Provisionamento credores (merge WEB + Delphi por CNPJ) ----
# pnpm provision:credores:dry   # simula
# pnpm provision:credores       # aplica (requer migration 009 no Supabase)
# ABEDELPHI_REQUEST_TIMEOUT_MS=120000
# ABEDELPHI_SYNC_DATA_INICIAL=01/01/2026
# ABEDELPHI_SYNC_DATA_FINAL=31/12/2026

# ---- AvantPay — a definir (API ou BD; preencher quando houver spec) ----
# AVANTPAY_API_URL=
# AVANTPAY_API_KEY=
# AVANTPAY_DB_HOST=
# AVANTPAY_DB_PORT=1433
# AVANTPAY_DB_NAME=
# AVANTPAY_DB_USER=
# AVANTPAY_DB_PASSWORD=

