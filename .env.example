# ============================================================================
# Exemplo de variáveis de ambiente — COPIE para .env e preencha localmente.
# NUNCA versione o arquivo .env real (ele está no .gitignore).
# Em produção, os segredos vêm do AWS Secrets Manager, não deste arquivo.
# ============================================================================

# Ambiente: development | staging | production
NODE_ENV=development

# ---- Backend (apps/api) ----
API_PORT=3333
API_GLOBAL_PREFIX=api
# URL do frontend autorizada no CORS
WEB_ORIGIN=http://localhost:3000

# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/painel_abe?schema=public

# Autenticação (OIDC) — preencher conforme provedor escolhido (Cognito/Keycloak)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
JWT_AUDIENCE=

# ---- Frontend (apps/web) ----
# Apenas variáveis públicas devem usar o prefixo NEXT_PUBLIC_
NEXT_PUBLIC_API_BASE_URL=/api
API_INTERNAL_URL=http://localhost:3333
